{
	"name": "cicd",
	"dockerComposeFile": [
		"docker-compose.yaml"
	],
	"service": "devcontainer",
	"workspaceFolder": "/workspaces/cicd",
	"postCreateCommand": "cd $WORKSPACE/",
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "bash",
						"icon": "terminal-bash"
					}
				},
				"files.exclude": {
					"**/.git": true,
					"**/.svn": true,
					"**/.hg": true,
					"**/CVS": true,
					"**/.DS_Store": true,
					"**/bin": true,
					"**/obj": true,
					"**/.vs": true
				},
				"editor.formatOnSave": true,
				"[dockerfile]": {
					"editor.formatOnSave": false
				}
			},
			"extensions": [
				"ms-azuretools.vscode-docker",
				"yzhang.markdown-all-in-one",
				"hashicorp.terraform",
				"github.vscode-github-actions"
			]
		}
	}
}