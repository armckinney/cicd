{
	"name": "cicd",
	"dockerComposeFile": [
		"docker-compose.yaml"
	],
	"service": "devcontainer",
	"workspaceFolder": "/workspaces/cicd",
	"postCreateCommand": "cd $WORKSPACE/",
	"features": {
		"https://github.com/armckinney/containers/releases/download/v1.0.6/devcontainer-feature-vscode-customizations.tgz": {},
		"https://github.com/armckinney/containers/releases/download/v1.0.6/devcontainer-feature-copilot.tgz": {},
		"https://github.com/armckinney/containers/releases/download/v1.0.6/devcontainer-feature-antigravity.tgz": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"hashicorp.terraform",
				"github.vscode-github-actions"
			]
		}
	}
}